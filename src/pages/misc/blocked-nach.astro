---
import Layout from '../../layouts/Layout.astro';
import blockedBanks from '../../datasets/npci/blocked-banks.json';
import blockedNach from '../../datasets/npci/blocked-nach.json';
import RawTable from '../../components/RawTable.astro';

const mappedBanks = blockedBanks.map((item) => ({
    "IFSC": item['IFSC'],
    "Bank Name": item['Bank Name'],
    "IIN": item['IIN'] || "N/A"
}));

const mappedNach = blockedNach.map((item: any) => ({
    "Institution": item['name'],
    "Reason": item['reason'],
    "Blocked From": item['blockedFrom']
}));
---

<Layout title="Blocked Banks on NACH | Misc | Banks in India" description="Live tracking directory of blacklisted or blocked institutions on the National Automated Clearing House (NACH) system.">
	<main id="main-content">
		<header>
			<h1 class="italic">Blocked Banks on NACH</h1>
		</header>
		
		<section aria-label="Regulatory Blocks">
            <h2>[Regulatory Actions]</h2>
            <p>High-profile institutions blocked from NACH due to regulatory directives or license cancellations.</p>
			<RawTable data={mappedNach} />
		</section>

		<section aria-label="Blocked Entities">
            <h2>[Blocked Entities]</h2>
            <p>Full list of {mappedBanks.length} institutions blocked from the NACH clearing system.</p>
			<RawTable data={mappedBanks} />
		</section>

	</main>
</Layout>
