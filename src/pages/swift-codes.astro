---
import Layout from '../layouts/Layout.astro';
import LazyTable from '../components/LazyTable.astro';
import names from '../datasets/core/names.json';

const swiftData = Object.entries(names).map(([prefix, bankName]) => ({
  "Financial Institution": bankName,
  "IFSC Prefix": prefix,
  "Estimated SWIFT": `${prefix}INBBXXX`
}));
---
<Layout title="SWIFT & BIC Code Directory | Banks in India" description="Estimated SWIFT / BIC code routing sequences for inward remittances into Indian banking institutions, derived from base IFSC prefix mappings.">
  <main id="main-content">
    <header>
      <h1 class="italic">SWIFT / BIC Codes Directory</h1>
      <p>Estimated global routing sequences for inward remittances into Indian banking institutions. Derived from base IFSC prefix alignments — verify with your bank before use.</p>
    </header>
    <section aria-label="SWIFT Code Directory">
      <h2>[Directory]</h2>
      <LazyTable data={swiftData} />
    </section>
  </main>
</Layout>
