---
import Layout from '../layouts/Layout.astro';
import BankSection from '../components/BankSection.astro';
import type { BanksData } from '../types/bank';
import banksData from '../datasets/core/banksData.json';

const { banks } = banksData as BanksData;
---

<Layout title="Banks in India">
	<main id="main-content">
		<header>
			<h1 class="italic">Banks in India</h1>
		</header>
		
		<section aria-label="Quick Actions">
			<ul>
			   <li>[Install] <code>npm i banks-in-india</code></li>
			   <li>[Library] <a href="https://methodblack.gumroad.com/l/banks-in-india" target="_blank" rel="noopener noreferrer">Figma icon library, $5</a></li>
			</ul>
		</section>
		
		{banks.map((section) => (
		  <BankSection 
			title={section.title} 
			category={section.category} 
			content={section.content} 
		  />
		))}
		

		
	</main>
</Layout>

<style>
ol, ul {
  list-style: none;
  margin: 0;
  padding: 0;
}
</style>

