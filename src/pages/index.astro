---
import Layout from '../layouts/Layout.astro';
import BankSection from '../components/BankSection.astro';
import type { BanksData } from '../types/bank';
import banksData from '../datasets/banksData.json';

const { banks } = banksData as BanksData;
---

<Layout title="Banks in India">
	<main id="main-content">
		<header>
			<h1 class="italic">Banks in India</h1>
		</header>
		
		<section aria-label="Quick Actions">
			<ul>
			   <li>[Install] <code>npm i banks-in-india</code></li>
			   <li>[Library] <a href="https://methodblack.gumroad.com/l/banks-in-india" target="_blank" rel="noopener noreferrer">Figma icon library, $5</a></li>
			</ul>
		</section>
		
		{banks.map((section) => (
		  <BankSection 
			title={section.title} 
			category={section.category} 
			content={section.content} 
		  />
		))}
		
		<nav aria-label="External Resources">
			<h2>[Misc]</h2>
				<li><a href="https://www.rbi.org.in/scripts/banklinks.aspx" target="_blank" rel="noopener noreferrer">RBI Listing</a><span aria-hidden="true">↗</span></li>
				<li><a href="https://rbidocs.rbi.org.in/rdocs/content/docs/68774.xlsx" target="_blank" rel="noopener noreferrer">NEFT IFSCs</a><span aria-hidden="true">↗</span></li>
				<li><a href="https://rbidocs.rbi.org.in/rdocs/RTGS/DOCs/RTGEB0815.xlsx" target="_blank" rel="noopener noreferrer">RTGS IFSCs</a><span aria-hidden="true">↗</span></li>
				<li><a href="https://www.npci.org.in/what-we-do/nach/live-members/live-banks" target="_blank" rel="noopener noreferrer">Banks Live on NACH</a><span aria-hidden="true">↗</span></li>
				<li><a href="https://www.npci.org.in/what-we-do/imps/live-members" target="_blank" rel="noopener noreferrer">Banks Live on IMPS</a><span aria-hidden="true">↗</span></li>
				<li><a href="https://www.npci.org.in/what-we-do/autopay/list-of-banks-and-apps-live-on-autopay" target="_blank" rel="noopener noreferrer">Banks Live on AutoPay</a><span aria-hidden="true">↗</span></li>
				<li><a href="https://www.npci.org.in/what-we-do/rupay/live-members" target="_blank" rel="noopener noreferrer">RuPay Live Members</a><span aria-hidden="true">↗</span></li>
				<li><a href="https://www.npci.org.in/PDF/npci/ifsc-and-micr-codes/Merged-banks-IFSC-and-MICR.xlsx" target="_blank" rel="noopener noreferrer">Merged banks Codes</a><span aria-hidden="true">↗</span></li>
				<li><a href="https://www.npci.org.in/what-we-do/nach/live-members/blocked-banks" target="_blank" rel="noopener noreferrer">Blocked Banks on NACH</a><span aria-hidden="true">↗</span></li>
			</ul>
		</nav>
		
		<footer>
			<p>[By] <a href="https://planetabhi.com/" target="_blank" rel="noopener noreferrer">@planetabhi</a> (^０^)ノ</p>
			<figure class="badge-link">
				<a href="https://www.jsdelivr.com/package/npm/banks-in-india" target="_blank" rel="noopener noreferrer">
					<img src="https://data.jsdelivr.com/v1/package/npm/banks-in-india/badge" alt="jsDelivr downloads badge" loading="lazy" />
				</a>
			</figure>
		</footer>
	</main>
</Layout>

<style>
ol, ul {
  list-style: none;
  margin: 0;
  padding: 0;
}
</style>

