---
import Layout from '../layouts/Layout.astro';
import LazyTable from '../components/LazyTable.astro';
import bsrData from '../datasets/rbi/bsr-codes.json';

const cleanBsr = bsrData.map(d => ({
  "IFSC": d["IFSC"],
  "Bank": d["BANK"],
  "Branch": d["BRANCH"],
  "City": d["CITY1"]
}));
---
<Layout title="BSR Routing Directory | Banks in India" description="Explore the Basic Statistical Return (BSR) codes matrix mapped out for branch-level tax routing identification used by Indian institutions.">
  <main id="main-content">
    <header>
      <h1 class="italic">BSR & Tax Routing Directory</h1>
      <p>Branch-level IFSC indexing utilized for official corporate taxation (TDS/TCS) processing pipelines. Showing all {cleanBsr.length.toLocaleString()} records.</p>
    </header>
    <section aria-label="BSR Codes Directory">
      <h2>[Directory]</h2>
      <LazyTable data={cleanBsr} />
    </section>
  </main>
</Layout>
