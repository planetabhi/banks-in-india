---
import Layout from '../layouts/Layout.astro';
import banksDataJSON from '../datasets/core/banksData.json';

const uniqueBanks = Array.from(
    banksDataJSON.banks.flatMap((group: any) => group.content).reduce((map: any, bank: any) => {
        if (!map.has(bank.ifsc)) {
            map.set(bank.ifsc, bank);
        }
        return map;
    }, new Map()).values()
);

const iconMap = uniqueBanks.reduce((acc: any, bank: any) => {
    acc[bank.ifsc] = bank.icon;
    return acc;
}, {});
---

<Layout title="IFSC Code Search | Banks in India" description="Quickly search, find, verify, and copy the accurate IFSC, MICR, address, and live network support for any Indian banking branch.">
	<main id="main-content">
		<header>
			<h1 class="italic">IFSC Code Search</h1>
		</header>
		
		<section aria-label="Search Form">
            <h2>[Search]</h2>
            <form id="ifsc-form" autocomplete="off">
                <ul>
                    <li>
                        <label for="ifsc-input">[Query]</label> <input type="text" id="ifsc-input" name="ifsc" placeholder="e.g. HDFC0000001" required pattern="^[A-Z]{4}0[A-Z0-9]{6}$" title="Enter a valid 11-character IFSC code" />
                    </li>
                    <li>
                        [Action] <button type="submit">Search</button>
                    </li>
                </ul>
            </form>
            <ul id="recent-searches" hidden style="margin-top: 1rem;">
            </ul>
        </section>

        <section aria-label="Search Results">
            <ul id="loading" hidden>
                <li>[Status] Searching...</li>
            </ul>
            
            <ul id="error-message" hidden>
            </ul>
            
            <script id="icon-map" type="application/json" set:html={JSON.stringify(iconMap)}></script>
            <ul id="result-card" style="display: none; grid-template-columns: max-content 1fr; align-items: center;">
                <li style="display: contents;">
                    <span>[Bank]</span> 
                    <span style="display: flex; gap: 0.5rem; align-items: center; color: var(--content-inked);">
                        <img id="res-icon" src="" alt="bank logo" width="24" height="24" hidden /> 
                        <span id="res-bank" style="color: inherit;"></span>
                    </span>
                </li>
                <li style="display: contents;"><span>[Branch]</span> <span id="res-branch" style="color: var(--content-inked);"></span></li>
                <li style="display: contents;"><span>[Address]</span> <span id="res-address" style="color: var(--content-inked);"></span></li>
                <li style="display: contents;"><span>[Location]</span> <span style="color: var(--content-inked);"><span id="res-city" style="color: inherit;"></span>, <span id="res-state" style="color: inherit;"></span></span></li>
                <li style="display: contents;"><span>[MICR]</span> <span id="res-micr" style="color: var(--content-inked);"></span></li>
                <li style="display: contents;"><span>[Supported]</span> <span id="res-supported" style="color: var(--content-inked);"></span></li>
                <li style="display: contents;"><span>[Action]</span> <span style="color: var(--content-inked);"><button type="button" id="copy-btn">Copy Details</button></span></li>
            </ul>
		</section>

	</main>
</Layout>

<script>
    const form = document.getElementById('ifsc-form') as HTMLFormElement;
    const input = document.getElementById('ifsc-input') as HTMLInputElement;
    const loading = document.getElementById('loading')!;
    const errorMessage = document.getElementById('error-message')!;
    const resultCard = document.getElementById('result-card')!;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
    const recentSearchesContainer = document.getElementById('recent-searches')!;

    let currentData: any = null;
    let fetchController: AbortController | null = null;

    function renderRecent() {
        let recent: string[] = [];
        try {
            const parsed = JSON.parse(localStorage.getItem('recent_ifsc') || '[]');
            recent = Array.isArray(parsed) ? parsed.filter((item: any) => typeof item === 'string') : [];
        } catch(e) { /* ignore corrupted history */ }
        
        if (recent.length === 0) {
            recentSearchesContainer.hidden = true;
            return;
        }
        
        recentSearchesContainer.textContent = '';
        const li = document.createElement('li');
        const span = document.createElement('span');
        span.textContent = '[Recent] ';
        li.appendChild(span);
        
        recent.forEach((item, index) => {
            const a = document.createElement('a');
            a.setAttribute('href', `?q=${encodeURIComponent(item)}`);
            a.className = 'recent-link';
            a.textContent = item;
            a.addEventListener('click', (e) => {
                e.preventDefault();
                input.value = item;
                searchIFSC(item);
            });
            li.appendChild(a);
            
            if (index < recent.length - 1) {
                li.appendChild(document.createTextNode(', '));
            }
        });
        
        recentSearchesContainer.appendChild(li);
        recentSearchesContainer.hidden = false;
    }

    function saveRecent(ifsc: string) {
        try {
            let recent: string[] = [];
            const parsed = JSON.parse(localStorage.getItem('recent_ifsc') || '[]');
            recent = Array.isArray(parsed) ? parsed.filter((item: any) => typeof item === 'string') : [];
            
            // Add to front, remove duplicates, keep top 5
            recent = [ifsc, ...recent.filter((i: string) => i !== ifsc)].slice(0, 5);
            localStorage.setItem('recent_ifsc', JSON.stringify(recent));
        } catch(e) { /* privacy mode limits localStorage */ }
        renderRecent();
    }

    async function searchIFSC(ifsc: string) {
        if (!ifsc.match(/^[A-Z]{4}0[A-Z0-9]{6}$/)) return;
        
        if (fetchController) fetchController.abort();
        fetchController = new AbortController();
        const { signal } = fetchController;

        loading.hidden = false;
        errorMessage.hidden = true;
        resultCard.style.display = 'none';
        currentData = null;

        // Update URL for sharable links
        const url = new URL(window.location.href);
        url.searchParams.set('q', ifsc);
        window.history.replaceState({}, '', url);

        try {
            const response = await fetch(`https://ifsc.razorpay.com/${ifsc}`, { signal });
            if (!response.ok) {
                if (response.status === 404) {
                    throw new Error("IFSC code not found. Please double-check it. Remember, the 5th character is always a zero '0'.");
                }
                throw new Error("An error occurred while fetching data.");
            }
            
            const data = await response.json();
            currentData = data;
            
            document.getElementById('res-bank')!.textContent = data.BANK;
            
            const iconMapData = JSON.parse(document.getElementById('icon-map')?.textContent || '{}');
            const ifscPrefix = ifsc.substring(0, 4).toUpperCase();
            const resIcon = document.getElementById('res-icon') as HTMLImageElement;
            if (iconMapData[ifscPrefix]) {
                resIcon.src = iconMapData[ifscPrefix];
                resIcon.hidden = false;
            } else {
                resIcon.hidden = true;
            }
            document.getElementById('res-branch')!.textContent = data.BRANCH;
            document.getElementById('res-address')!.textContent = data.ADDRESS;
            document.getElementById('res-city')!.textContent = data.CITY;
            document.getElementById('res-state')!.textContent = data.STATE;
            document.getElementById('res-micr')!.textContent = data.MICR || 'N/A';
            
            const supported = [];
            if (data.NEFT) supported.push('NEFT');
            if (data.RTGS) supported.push('RTGS');
            if (data.IMPS) supported.push('IMPS');
            if (data.UPI) supported.push('UPI');
            document.getElementById('res-supported')!.textContent = supported.join(', ') || 'None';

            resultCard.style.display = 'grid';
            saveRecent(ifsc);
        } catch (err) {
            if ((err as Error).name === 'AbortError') return;
            errorMessage.innerHTML = `<li>[Error] ${(err as Error).message}</li>`;
            errorMessage.hidden = false;
        } finally {
            if (fetchController?.signal === signal) {
                loading.hidden = true;
            }
        }
    }

    form.addEventListener('submit', (e) => {
        e.preventDefault();
        searchIFSC(input.value.trim().toUpperCase());
    });

    input.addEventListener('input', () => {
        let val = input.value.toUpperCase();
        
        // Input Sanitization: Ensure the 5th character is a zero
        if (val.length >= 5) {
            val = val.substring(0, 4) + '0' + val.substring(5);
        }
        
        // Input Sanitization: Strip invalid characters
        val = val.replace(/[^A-Z0-9]/g, '');
        input.value = val;

        // Auto-Submit: Fire exactly when length is 11 and valid
        if (val.match(/^[A-Z]{4}0[A-Z0-9]{6}$/)) {
            searchIFSC(val);
        }
    });

    copyBtn.addEventListener('click', () => {
        if (!currentData) return;
        const textToCopy = `Bank: ${currentData.BANK}\nBranch: ${currentData.BRANCH}\nIFSC: ${currentData.IFSC}\nAddress: ${currentData.ADDRESS}\nLocation: ${currentData.CITY}, ${currentData.STATE}`;
        
        navigator.clipboard.writeText(textToCopy).then(() => {
            const originalText = copyBtn.textContent;
            copyBtn.textContent = 'Copied!';
            setTimeout(() => {
                copyBtn.textContent = originalText;
            }, 2000);
        });
    });

    // Check URL parameters on mount
    document.addEventListener("DOMContentLoaded", () => {
        const params = new URLSearchParams(window.location.search);
        const q = params.get('q');
        if (q) {
            input.value = q.toUpperCase();
            searchIFSC(q.toUpperCase());
        }
        
        // Load recent searches
        renderRecent();
    });
</script>

<style>
ol, ul {
  list-style: none;
  margin: 0;
  padding: 0;
}
</style>
