---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { 
	title, 
	description = "Comprehensive directory of all active Indian banks with IFSC codes, logos, and official websites. Includes public sector, private sector, small finance, payment banks, regional rural banks, and foreign banks." 
} = Astro.props;

/* One URL per path: ignore querystrings (e.g. ?q=) for canonical to avoid duplicate indexing. */
const pathNorm = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalHref =
	pathNorm === '/' ? 'https://banksin.in/' : `https://banksin.in${pathNorm}`;

const isHome = pathNorm === '/';

const structuredData = isHome
	? {
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: 'Banks in India',
			url: 'https://banksin.in/',
			description,
			inLanguage: 'en-IN',
			author: {
				'@type': 'Person',
				name: 'Abhimanyu Rana',
				url: 'https://planetabhi.com/',
			},
			publisher: {
				'@type': 'Organization',
				name: 'Banks in India',
				url: 'https://banksin.in/',
			},
			potentialAction: {
				'@type': 'SearchAction',
				target: {
					'@type': 'EntryPoint',
					urlTemplate: 'https://banksin.in/ifsc-search?q={search_term_string}',
				},
				'query-input': 'required name=search_term_string',
			},
	  }
	: {
			'@context': 'https://schema.org',
			'@type': 'WebPage',
			name: title,
			url: canonicalHref,
			description,
			inLanguage: 'en-IN',
			isPartOf: {
				'@type': 'WebSite',
				name: 'Banks in India',
				url: 'https://banksin.in/',
			},
			author: {
				'@type': 'Person',
				name: 'Abhimanyu Rana',
				url: 'https://planetabhi.com/',
			},
			publisher: {
				'@type': 'Organization',
				name: 'Banks in India',
				url: 'https://banksin.in/',
			},
	  };

const hasRightSidebar = Astro.slots.has('sidebar-right');
---

<!doctype html>
<html lang="en" data-new-ui-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content="indian banks, ifsc codes, bank directory, banking india, rbi banks, private banks, public sector banks, payment banks, small finance banks, regional rural banks, foreign banks, neft, rtgs, npci" />
		<meta name="robots" content="index, follow" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalHref} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalHref} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:site_name" content="Banks in India" />
		<meta property="og:locale" content="en_IN" />
		<meta property="og:image" content="https://banksin.in/og-image.png" />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalHref} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://banksin.in/og-image.png" />
		<meta name="twitter:creator" content="@planetabhi" />
		
		<!-- Favicons -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		
		<!-- Theme Color -->
		<meta name="theme-color" content="#ff69b4" />
		
		<!-- Performance: Font Preloading -->
		<link rel="preload" href="/fonts/Mono-Regular.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/Mono-Italic.woff2" as="font" type="font/woff2" crossorigin />
		
		<!-- Performance: DNS Prefetch -->
		<link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
		<link rel="dns-prefetch" href="https://data.jsdelivr.com" />
		<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
		
		<!-- Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to main content</a>
		<div class:list={['layout-wrapper', { 'layout-wrapper--with-rhs': hasRightSidebar }]}>
			<aside class="sidebar" id="main-nav">
				<nav aria-label="Main Navigation">
					<ul>
						{[
							{ label: 'Banks in India', href: '/' },
							{ label: 'IFSC Search', href: '/ifsc-search' },
							{ label: 'NEFT Branches', href: '/misc/neft-ifscs' },
							{ label: 'RTGS Branches', href: '/misc/rtgs-ifscs' },
							{ label: 'Merged Banks', href: '/misc/merged-banks' },
							{ label: 'Blocked Banks', href: '/misc/blocked-nach' },
							{ label: 'SWIFT Directory', href: '/swift-codes' },
							{ label: 'Payment Networks', href: '/payment-networks' },
							{ label: 'BSR Codes', href: '/bsr-codes' }
						].map(item => {
							// Astro.url.pathname can sometimes be with or without a trailing slash
							const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
							const basePath = item.href.replace(/\/$/, '') || '/';
							const isActive = currentPath === basePath;
							
							return (
								<li>
									<a 
										href={item.href} 
										aria-current={isActive ? 'page' : undefined}
										style={isActive ? 'color: var(--selected);' : undefined}
									>
										{item.label}
									</a>
								</li>
							);
						})}
					</ul>
				</nav>
				
				<footer>
					<div class="footer-badge">
						<a href="https://makeforindia.com/" target="_blank" rel="noopener noreferrer">
						<svg xmlns="http://www.w3.org/2000/svg" width="199" height="50" fill="none"><rect width="198" height="49" x=".5" y=".5" stroke="#A8A8A8" rx="5.5"/><path stroke="#161616" stroke-miterlimit="16" d="M54.647 12.12c0 .065-.212.153-.47.195-.26.042-.5.152-.535.244-.035.091-.195.167-.356.167-.16 0-.313.064-.34.142-.032.1-.541.145-1.687.151-1.067.006-1.67.056-1.726.144-.047.074-.211.175-.366.223-.306.097-.735.482-.735.66 0 .178-.718.856-.906.856-.093 0-.17.053-.17.117s-.269.153-.597.197c-.329.044-.598.12-.598.168 0 .048-.492.12-1.094.159-.602.04-1.127.12-1.166.18-.039.061-.552.147-1.14.191-.59.045-1.102.133-1.14.195-.038.062-.86.15-1.828.197-.968.046-1.76.13-1.76.187 0 .161-1.168.123-1.221-.04-.065-.197-9.383-.223-9.51-.028-.046.073-.296.167-.553.208-.258.041-.5.123-.538.183-.038.06-.325.147-.637.193-.313.047-.568.13-.568.187 0 .056-.269.14-.598.185-.328.046-.597.129-.597.183 0 .055-.35.138-.777.185-.427.046-.777.132-.777.19 0 .06-.887.108-1.972.108-1.095 0-1.972.048-1.972.109 0 .06-.578.149-1.285.197-.707.048-1.317.139-1.357.202-.04.063-.296.145-.568.182-.272.037-.495.11-.495.165 0 .053-.239.133-.53.177-.292.045-.559.157-.594.25a.284.284 0 0 1-.247.169c-.1 0-.183.048-.183.107 0 .06-.145.145-.323.19-.177.045-.444.214-.592.376-.148.162-.316.294-.374.294-.163 0-1.101.912-1.101 1.07 0 .077-.053.14-.118.14-.064 0-.153.15-.197.332-.045.183-.14.371-.212.419-.188.124-.18 3.943.01 4.061.076.048.176.237.221.419.045.182.13.331.189.331s.107.082.107.182c0 .1.08.181.179.181.098 0 .179.076.179.168 0 .093.134.203.299.244.164.042.299.13.299.195s.078.119.173.119c.095 0 .216.076.269.17.052.093.23.188.394.211.23.032.308.124.339.394.045.4.545.961.98 1.099.162.051.333.154.38.228.057.089.637.132 1.704.127l1.617-.008v.4c0 .221.054.402.12.402.07 0 .12.463.12 1.149 0 .685-.05 1.149-.12 1.149-.066 0-.12.108-.12.241s.054.242.12.242c.065 0 .12.163.12.363 0 .2.05.363.11.363.062 0 .15.122.196.272.046.15.134.304.194.344.06.04.142.38.18.756.038.376.112.684.163.684.051 0 .128.158.17.351.051.238.17.376